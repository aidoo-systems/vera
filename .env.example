BACKEND_PORT=8000
FRONTEND_PORT=3000
DATA_DIR=./data
SQLITE_PATH=./data/vera.db
DATABASE_URL=postgresql+psycopg://vera:vera@localhost:5432/vera
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
POSTGRES_USER=vera
POSTGRES_PASSWORD=vera
POSTGRES_DB=vera
POSTGRES_PORT=5432
REDIS_PORT=6379

# Ollama settings (optional — VERA degrades gracefully if unavailable)
# Docker: http://ollama:11434 (requires ollama_network)
# Local dev: http://localhost:11434
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT=300

# Backup settings (postgres pg_dump, runs in the backup service container)
BACKUP_HOST_DIR=./backups
BACKUP_RETENTION_DAYS=7
BACKUP_INTERVAL_SECONDS=86400

# Celery worker resource limits (used by docker-compose deploy.resources)
WORKER_MEMORY_LIMIT=4G
WORKER_CPU_LIMIT=2.0
BACKEND_MEMORY_LIMIT=1G

# Stuck-task recovery: documents stuck in processing longer than this are auto-failed
STUCK_TASK_TIMEOUT_MINUTES=30

# Redis password (used by redis-server --requirepass and Celery broker URLs)
REDIS_PASSWORD=vera_redis

# Hub integration (centralised identity)
HUB_BASE_URL=http://hub:8000
HUB_AUTH_API_KEY=
